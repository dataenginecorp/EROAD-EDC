                "schema_name": "AWS_APAC",
                "text": "CREATE SECURE VIEW \"DEV_EDC\".\"AWS_APAC\".\"SVW_DIM_DRIVER\" AS \r\nSELECT \r\n     ID, \r\n    dt.ORGANISATION_ID, \r\n    DRIVER_EXTERNAL_ID, \r\n    DRIVER_LICENSE_ID, \r\n    ALIAS_NAME, \r\n    FIRST_NAME, \r\n    LAST_NAME, \r\n    EMAIL, \r\n    MOBILE_NUMBER, \r\n    LICENSE_JURISDICTION, \r\n    TERMINAL_ID, \r\n    ACTIVE \r\nFROM DEV_EDC.AWS_APAC.DT_DIM_DRIVER dt\r\n INNER JOIN DEV_EDC.METADATA.ACCOUNT_ORGANISATION_ACCESS aoa\r\n ON CURRENT_ACCOUNT() = aoa.ACCOUNT_NAME \r\n AND dt.organisation_id = aoa.organisation_id;"
              }
            ],
            "statement": "SELECT \r\n     ID, \r\n    dt.ORGANISATION_ID, \r\n    DRIVER_EXTERNAL_ID, \r\n    DRIVER_LICENSE_ID, \r\n    ALIAS_NAME, \r\n    FIRST_NAME, \r\n    LAST_NAME, \r\n    EMAIL, \r\n    MOBILE_NUMBER, \r\n    LICENSE_JURISDICTION, \r\n    TERMINAL_ID, \r\n    ACTIVE \r\nFROM DEV_EDC.AWS_APAC.DT_DIM_DRIVER dt\r\n INNER JOIN DEV_EDC.METADATA.ACCOUNT_ORGANISATION_ACCESS aoa\r\n ON CURRENT_ACCOUNT() = aoa.ACCOUNT_NAME \r\n AND dt.organisation_id = aoa.organisation_id;",
