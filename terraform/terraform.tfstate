          "index_key": "dim_geofence.AWS_APAC",
          "schema_version": 0,
          "attributes": {
            "automatic_clustering": false,
            "bytes": 0,
            "cluster_by": "",
            "comment": "Managed by Terraform",
            "created_on": "2026-03-16T11:54:04+13:00",
            "data_timestamp": "2026-03-16T36:54:04.483 +1300",
            "database": "DEV_EDC",
            "fully_qualified_name": "\"DEV_EDC\".\"AWS_APAC\".\"DT_DIM_GEOFENCE\"",
            "id": "DEV_EDC|AWS_APAC|DT_DIM_GEOFENCE",
            "initialize": "ON_CREATE",
            "is_clone": false,
            "is_replica": false,
            "last_suspended_on": "0001-01-01T16:00:00.000 +0000",
            "name": "DT_DIM_GEOFENCE",
            "or_replace": false,
            "owner": "ACCOUNTADMIN",
            "query": "SELECT \r\ngf.ID, \r\ngf.COMMON_IDENTIFIER_GID as GEOFENCE_MAIN_ID, \r\ngf.ORGANISATION_ID, \r\ngf.NAME, \r\ngf.TYPES, \r\ngf.GEOMETRY, \r\ng.SPEED_LIMIT, \r\ngf.ACTIVE, \r\ngf.ORIGIN, \r\ngf.VALIDFROM_DATETIME, \r\ngf.VALIDTO_DATETIME \r\nFROM \"DEV\".core_extensions.geofence gf \r\nINNER JOIN \"DEV\".core.geofence g \r\nON gf.ID = g.ID \r\nAND g.SF_INACTIVE_DATE IS NULL \r\nINNER JOIN \"DEV\".\"EDC_INTERNAL\".\"ACCOUNT_ORGANISATION_ACCESS\" aoa\r\n  ON gf.ORGANISATION_ID = aoa.ORGANISATION_ID\r\n AND LOWER(aoa.REGION) = LOWER('apac')\r\n AND UPPER(aoa.CLOUD)  = UPPER('AWS');\r\n\r\n",
