            "module.edc_db_schema.snowflake_schema.edc_region",
            "module.edc_db_schema.snowflake_schema.metadata",
            "module.region_cloud.snowflake_execute.region_cloud",
            "module.wh.snowflake_warehouse.warehouse"
          ]
        }
      ]
