            "query": "SELECT \r\nms.GID as ID, \r\nms.ORGANISATION_ID, \r\nms.MACHINE_ID, \r\nms.SERVICE_TYPE_ID, \r\nconvert_timezone(org.TIMEZONE,concat(ms.PROCESSED_DATE::string,' +0000')::timestamp_tz)::date as PROCESSED_LOCAL_DATE, \r\nms.NEXT_SERVICE_ODOMETER, \r\nconvert_timezone(org.TIMEZONE,concat(ms.NEXT_SERVICE_DATE::string,' +0000')::timestamp_tz)::date as NEXT_SERVICE_LOCAL_DATE, \r\nms.NEXT_SERVICE_HOURS, \r\nms.INACTIVE, \r\nms.STATUS, \r\nms.SF_LOAD_DATE as LOAD_DATETIME \r\nFROM \"DEV\".core.maintenance_service_schedule ms \r\nINNER JOIN \"DEV\".core.organisation org \r\nON (org.GID = ms.ORGANISATION_ID AND org.SF_INACTIVE_DATE IS NULL) \r\nINNER JOIN \"DEV\".\"EDC_INTERNAL\".\"ACCOUNT_ORGANISATION_ACCESS\" aoa \r\n  ON ms.ORGANISATION_ID = aoa.ORGANISATION_ID\r\n AND LOWER(aoa.REGION) = LOWER('us-central1')\r\n AND UPPER(aoa.CLOUD)  = UPPER('GCP')\r\n WHERE ms.SF_INACTIVE_DATE IS NULL;",
            "refresh_mode": "AUTO",
            "refresh_mode_reason": "This dynamic table contains a complex query. Refresh mode has been set to FULL. If you wish to override this automatic choice, please re-create the dynamic table and specify REFRESH_MODE=INCREMENTAL. For best results, we recommend reading https://docs.snowflake.com/user-guide/dynamic-table-performance-guide before setting the refresh mode to INCREMENTAL.",
