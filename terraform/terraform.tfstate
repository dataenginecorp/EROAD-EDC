            "or_replace": false,
            "owner": "ACCOUNTADMIN",
            "query": "SELECT \r\nse.ID as ID, \r\nse.ORGANISATION_ID, \r\nse.MACHINE_GID as MACHINE_ID, \r\nse.MACHINE_ACTIVATION_ID, \r\nse.SENSOR_GID as SENSOR_ID, \r\nse.EVENT_TIMESTAMP as EVENT_DATETIME, \r\nse.EVENT_DATE, \r\nse.EVENT_LOCAL_DATETIME, \r\nse.EVENT_LOCAL_DATE, \r\ndc.DATAPOINT as ECM_SENSOR_TYPE_ID, \r\nse.SENSOR_VALUE, \r\n--se.PREV_SENSOR_VALUE, \r\nse.SF_LOAD_DATE as LOAD_DATETIME \r\nFROM \"DEV\".core_extensions.ecm_sensor_generic_sensor_event se \r\nINNER JOIN \"DEV\".core.sensor_device_config dc \r\non se.EXTERNAL_GID = dc.GID \r\nINNER JOIN \"DEV\".core.sensor_datapoint d \r\non d.ID = dc.DATAPOINT \r\nINNER JOIN \"DEV\".core.sensor_device d2 \r\non d2.ID = dc.DEVICE \r\nINNER JOIN \"DEV\".\"EDC_INTERNAL\".\"ACCOUNT_ORGANISATION_ACCESS\" aoa \r\n  ON se.ORGANISATION_ID = aoa.ORGANISATION_ID\r\n AND LOWER(aoa.REGION) = LOWER('westeurope')\r\n AND UPPER(aoa.CLOUD)  = UPPER('AZURE')\r\nWHERE dc.DATAPOINT IN (2, 3, 9, 10, 11, 14, 18, 22, 28, 31, 32, 33, 34, 35, 36, 37, 41, 42, 43, 44, 45, 47, 48, 50, 54, 56, 57, 58, 59, 60, 72, 73);",
