            "query": "SELECT \r\nID, \r\nft.ORGANISATION_ID, \r\nMACHINE_ID, \r\nDRIVER_ID, \r\nFUEL_TRANSACTION_ID, \r\nTRANSACTION_DATETIME,\r\nTRANSACTION_LOCAL_DATETIME, \r\nTRANSACTION_LOCAL_DATE, \r\nSUPPLIER, \r\nCUSTOMER_NAME, \r\nCUSTOMER_ACCOUNT_NUMBER, \r\nPRODUCT_CODE, \r\nQUANTITY, \r\nIFF(ODOMETER \u003e= PREV_ODOMETER, ROUND((ODOMETER - PREV_ODOMETER), 3), DISTANCE) as DISTANCE, \r\nCOST, \r\nCONSUMER, \r\nTAX_PAID, \r\nSOURCE, \r\nSOURCE_COMPONENT, \r\nSF_LOAD_DATE as LOAD_DATETIME \r\nFROM \"DEV\".core_extensions.fuel_transaction ft \r\nINNER JOIN \"DEV\".\"EDC_INTERNAL\".\"ACCOUNT_ORGANISATION_ACCESS\" aoa \r\n  ON ft.ORGANISATION_ID = aoa.ORGANISATION_ID\r\n AND LOWER(aoa.REGION) = LOWER('us-central1')\r\n AND UPPER(aoa.CLOUD)  = UPPER('GCP')\r\nWHERE PROCESSING_STATUS != 'REJECTED';",
            "refresh_mode": "AUTO",
