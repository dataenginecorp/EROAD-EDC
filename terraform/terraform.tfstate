            "name": "DT_FACT_LOGBOOK_EVENT_EDIT",
            "or_replace": false,
            "owner": "ACCOUNTADMIN",
            "query": "SELECT \r\nSTATUS_CHANGE_ID as ID, \r\nte.ORGANISATION_ID, \r\nDRIVER_ID, \r\nVALID_TIME_UTC as EVENT_DATETIME, \r\nEVENT_LOCAL_DATETIME, \r\nEVENT_LOCAL_DATE, \r\nSTATUS_STRING as STATUS, \r\nLATITUDE, \r\nLONGITUDE, \r\nSUBURB_FROM_GPS, \r\nSUBURB_ENTERED, \r\nCREATED_DATETIME, \r\nLASTMODIFIED_DATETIME, \r\nREGISTRATION, \r\nVEHICLE_TYPE_STRING as VEHICLE_TYPE, \r\nODOMETER, \r\nNOTES, \r\nEDIT_INDEX AS EDITS, \r\nLOAD_DATETIME \r\nFROM \"DEV\".core_extensions.timely_event_historic_union te \r\nINNER JOIN \"DEV\".\"EDC_INTERNAL\".\"ACCOUNT_ORGANISATION_ACCESS\" aoa \r\n  ON te.ORGANISATION_ID = aoa.ORGANISATION_ID\r\n AND LOWER(aoa.REGION) = LOWER('us-central1')\r\n AND UPPER(aoa.CLOUD)  = UPPER('GCP');",
