            "fully_qualified_name": "\"DEV_EDC\".\"AZURE_WESTEUROPE\".\"DT_DIM_MACHINE\"",
            "id": "DEV_EDC|AZURE_WESTEUROPE|DT_DIM_MACHINE",
            "initialize": "ON_CREATE",
            "is_clone": false,
            "is_replica": false,
            "last_suspended_on": "0001-01-01T16:00:00.000 +0000",
            "name": "DT_DIM_MACHINE",
            "or_replace": false,
            "owner": "ACCOUNTADMIN",
            "query": "SELECT \r\nam.ID, \r\nam.ORGANISATION_ID, \r\nMAKE, \r\nMODEL, \r\nVIN, \r\nMACHINE_TYPE, \r\nYEAR_OF_MANUFACTURE, \r\nVEHICLE_WEIGHT_TYPE, \r\nIS_RUC_VEHICLE, \r\nAXLE_COUNT, \r\nFUEL_TYPE, \r\nCURRENTLY_ACTIVE, \r\nACTIVE_REGISTRATION_PLATE, \r\nACTIVE_DISPLAY_NAME, \r\nACTIVE_ASSET_CODE, \r\nam.COST_CENTER AS ACTIVE_COST_CENTER, \r\nohm.TIMEZONE, \r\nFALSE as IS_SHARED \r\nFROM \"DEV\".core_extensions.all_machine am \r\nLEFT JOIN \"DEV\".core.organisation_has_machines ohm \r\nON am.ID = ohm.MACHINE_ID \r\nand am.ORGANISATION_ID = ohm.ORGANISATION_ID \r\nand ohm.END_DATE is null \r\nand ohm.SF_INACTIVE_DATE is null \r\nINNER JOIN \"DEV\".\"EDC_INTERNAL\".\"ACCOUNT_ORGANISATION_ACCESS\" aoa \r\n  ON am.ORGANISATION_ID = aoa.ORGANISATION_ID\r\n AND LOWER(aoa.REGION) = LOWER('westeurope')\r\n AND UPPER(aoa.CLOUD)  = UPPER('AZURE')\r\n\r\nUNION\r\n\r\nSELECT \r\nasm.ID, \r\nasm.ORGANISATION_ID, \r\nMAKE, \r\nMODEL, \r\nVIN, \r\nMACHINE_TYPE, \r\nYEAR_OF_MANUFACTURE, \r\nVEHICLE_WEIGHT_TYPE, \r\nIS_RUC_VEHICLE, \r\nAXLE_COUNT, \r\nFUEL_TYPE, \r\nCURRENTLY_ACTIVE, \r\nACTIVE_REGISTRATION_PLATE, \r\nACTIVE_DISPLAY_NAME, \r\nACTIVE_ASSET_CODE, \r\nasm.COST_CENTER AS ACTIVE_COST_CENTER, \r\nohm.TIMEZONE, \r\nTRUE as IS_SHARED \r\nFROM \"DEV\".core_extensions.all_shared_machine asm \r\nLEFT JOIN \"DEV\".core.organisation_has_machines ohm \r\nON asm.ID = ohm.MACHINE_ID \r\nAND asm.ORGANISATION_ID = ohm.ORGANISATION_ID \r\nAND ohm.END_DATE is null \r\nAND ohm.SF_INACTIVE_DATE is null \r\nINNER JOIN \"DEV\".\"EDC_INTERNAL\".\"ACCOUNT_ORGANISATION_ACCESS\" aoa \r\n  ON asm.ORGANISATION_ID = aoa.ORGANISATION_ID\r\n AND LOWER(aoa.REGION) = LOWER('westeurope')\r\n AND UPPER(aoa.CLOUD)  = UPPER('AZURE');\r\n",
