            "query": "SELECT UUID_STRING(l.ORGANISATION_ID, NVL(l.MACHINE_ID,'-1') || l.CENTRAL_ID) as ID, \r\nl.ORGANISATION_ID, \r\nMACHINE_ID, \r\nNUMBER as ISSUE_NUMBER, \r\nISSUE_DATETIME, \r\nISSUE_LOCAL_DATETIME, \r\nCONTINUATION, \r\nSTART_DISTANCE, \r\nEND_DISTANCE, \r\nUNITS, \r\nVEHICLE_WEIGHT, \r\nTYPE_NAME as LICENCE_TYPE, \r\nSTATUS, \r\nSTATUS_LAST_MODIFIED_DATETIME, \r\nSTATUS_LAST_MODIFIED_LOCAL_DATETIME, \r\nDOLLAR_VALUE, \r\nCREDIT, \r\nAMOUNT, \r\nREGISTRATION_PLATE, \r\nFEE_AMOUNT, \r\nFEE_AMOUNT_GST, \r\nRUC_VEHICLE_TYPE, \r\nVEHICLE_COMBINATION, \r\nRUC_WEIGHT_FLAG, \r\nLOAD_DATETIME \r\nFROM \"DEV\".core_extensions.vehicle_licence l \r\nINNER JOIN \"DEV\".\"EDC_INTERNAL\".\"ACCOUNT_ORGANISATION_ACCESS\" aoa \r\n  ON l.ORGANISATION_ID = aoa.ORGANISATION_ID\r\n AND LOWER(aoa.REGION) = LOWER('eastus')\r\n AND UPPER(aoa.CLOUD)  = UPPER('AZURE')\r\nWHERE l.ORGANISATION_ID IS NOT NULL QUALIFY ROW_NUMBER() OVER (PARTITION BY l.CENTRAL_ID, l.ORGANISATION_ID, l.MACHINE_ID ORDER BY l.LOAD_DATETIME DESC) = 1;\r\n",
            "refresh_mode": "AUTO",
            "refresh_mode_reason": "",
            "rows": 0,
            "scheduling_state": "ACTIVE",
            "schema": "AZURE_EASTUS",
