            "database": "DEV_EDC",
            "fully_qualified_name": "\"DEV_EDC\".\"AWS_APAC\".\"DT_FACT_VEHICLE_LEADERBOARD\"",
            "id": "DEV_EDC|AWS_APAC|DT_FACT_VEHICLE_LEADERBOARD",
            "initialize": "ON_CREATE",
            "is_clone": false,
            "is_replica": false,
            "last_suspended_on": "0001-01-01T16:00:00.000 +0000",
            "name": "DT_FACT_VEHICLE_LEADERBOARD",
            "or_replace": false,
            "owner": "ACCOUNTADMIN",
            "query": "select \r\nID, \r\nvl.ORGANISATION_ID, \r\nMACHINE_ID, \r\nEFFECTIVE_DATE_LOCALISED as EFFECTIVE_LOCAL_DATE, \r\nCURRENT_STARS, \r\nrank() over (partition by NVL(CENTRAL_VIEWING_ORGANISATION_ID,CENTRAL_ORGANISATION_ID),\r\nEFFECTIVE_DATE_LOCALISED ORDER BY CURRENT_SCORE DESC, DISTANCE DESC) as ORGANISATION_RANK, \r\nSHARED_MACHINE \r\nFROM \"DEV\".core_extensions.vehicle_leaderboard vl \r\nINNER JOIN \"DEV\".\"EDC_INTERNAL\".\"ACCOUNT_ORGANISATION_ACCESS\" aoa \r\n  ON vl.ORGANISATION_ID = aoa.ORGANISATION_ID\r\n AND LOWER(aoa.REGION) = LOWER('apac')\r\n AND UPPER(aoa.CLOUD)  = UPPER('AWS');",
