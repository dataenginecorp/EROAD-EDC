            "owner": "ACCOUNTADMIN",
            "query": "SELECT \r\nDISTINCT st.ID, \r\nst.ORGANISATION_ID, \r\nst.NAME, \r\nst.DESCRIPTION \r\nFROM \"DEV\".core.maintenance_service_type st \r\nINNER JOIN \"DEV\".\"EDC_INTERNAL\".\"ACCOUNT_ORGANISATION_ACCESS\" aoa \r\n  ON st.ORGANISATION_ID = aoa.ORGANISATION_ID\r\n AND LOWER(aoa.REGION) = LOWER('apac')\r\n AND UPPER(aoa.CLOUD)  = UPPER('AWS')\r\nWHERE st.ORGANISATION_ID IS NOT NULL \r\nUNION ALL \r\nSELECT DISTINCT \r\nast.ID, \r\naoa.ORGANISATION_ID, \r\nast.NAME, \r\nast.DESCRIPTION \r\nFROM \"DEV\".core.maintenance_service_type ast \r\nINNER JOIN \"DEV\".\"EDC_INTERNAL\".\"ACCOUNT_ORGANISATION_ACCESS\" aoa \r\n  ON ast.ORGANISATION_ID = aoa.ORGANISATION_ID\r\n AND LOWER(aoa.REGION) = LOWER('apac')\r\n AND UPPER(aoa.CLOUD)  = UPPER('AWS')\r\nINNER JOIN \"DEV\".core.organisation org \r\nON (org.GID = aoa.ORGANISATION_ID and org.ADDRESS_COUNTRY = ast.COUNTRY) \r\nWHERE ast.ORGANISATION_ID IS NULL AND ast.COUNTRY IS NOT NULL AND org.ADDRESS_COUNTRY IS NOT NULL;",
