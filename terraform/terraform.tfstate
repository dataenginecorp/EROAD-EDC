            "database": "DEV_EDC",
            "fully_qualified_name": "\"DEV_EDC\".\"AWS_APAC\".\"DT_FACT_VEHICLE_TRIP\"",
            "id": "DEV_EDC|AWS_APAC|DT_FACT_VEHICLE_TRIP",
            "initialize": "ON_CREATE",
            "is_clone": false,
            "is_replica": false,
