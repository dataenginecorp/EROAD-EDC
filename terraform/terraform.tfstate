            "name": "DT_DIM_GEOFENCE",
            "or_replace": false,
            "owner": "ACCOUNTADMIN",
            "query": "SELECT \r\ngf.ID, \r\ngf.COMMON_IDENTIFIER_GID as GEOFENCE_MAIN_ID, \r\ngf.ORGANISATION_ID, \r\ngf.NAME, \r\ngf.TYPES, \r\ngf.GEOMETRY, \r\ng.SPEED_LIMIT, \r\ngf.ACTIVE, \r\ngf.ORIGIN, \r\ngf.VALIDFROM_DATETIME, \r\ngf.VALIDTO_DATETIME \r\nFROM \"DEV\".core_extensions.geofence gf \r\nINNER JOIN \"DEV\".core.geofence g \r\nON gf.ID = g.ID \r\nAND g.SF_INACTIVE_DATE IS NULL \r\nINNER JOIN \"DEV\".\"EDC_INTERNAL\".\"ACCOUNT_ORGANISATION_ACCESS\" aoa\r\n  ON gf.ORGANISATION_ID = aoa.ORGANISATION_ID\r\n AND LOWER(aoa.REGION) = LOWER('westeurope')\r\n AND UPPER(aoa.CLOUD)  = UPPER('AZURE');\r\n\r\n",
