            "query": "SELECT DISTINCT \r\ns.ID, \r\nASSET_ID AS MACHINE_ID, \r\nTYPE AS CODE, \r\nGROUP_NAME AS \"GROUP\", \r\nSOURCE_NAME AS \"SOURCE\", \r\nSUBJECT_NAME AS DESCRIPTION \r\nFROM \"DEV\".core_extensions.ecm_sensor s \r\nINNER JOIN \"DEV\".core_extensions.shared_machine_activations_union smau \r\nON smau.MACHINE_ID=s.ASSET_ID \r\nINNER JOIN \"DEV\".\"EDC_INTERNAL\".\"ACCOUNT_ORGANISATION_ACCESS\" aoa\r\n  ON smau.ORGANISATION_ID = aoa.ORGANISATION_ID\r\n AND LOWER(aoa.REGION) = LOWER('apac')\r\n AND UPPER(aoa.CLOUD)  = UPPER('AWS');\r\n\r\n",
