        {
          "index_key": "fact_machine_distance_licence.AWS_APAC",
          "schema_version": 0,
          "attributes": {
            "automatic_clustering": false,
            "bytes": 0,
            "cluster_by": "",
            "comment": "Managed by Terraform",
            "created_on": "2026-03-16T11:54:32+13:00",
            "data_timestamp": "2026-03-16T36:54:32.767 +1300",
            "database": "DEV_EDC",
            "fully_qualified_name": "\"DEV_EDC\".\"AWS_APAC\".\"DT_FACT_MACHINE_DISTANCE_LICENCE\"",
            "id": "DEV_EDC|AWS_APAC|DT_FACT_MACHINE_DISTANCE_LICENCE",
            "initialize": "ON_CREATE",
            "is_clone": false,
            "is_replica": false,
            "last_suspended_on": "0001-01-01T16:00:00.000 +0000",
            "name": "DT_FACT_MACHINE_DISTANCE_LICENCE",
            "or_replace": false,
            "owner": "ACCOUNTADMIN",
            "query": "SELECT UUID_STRING(l.ORGANISATION_ID, NVL(l.MACHINE_ID,'-1') || l.CENTRAL_ID) as ID, \r\nl.ORGANISATION_ID, \r\nMACHINE_ID, \r\nNUMBER as ISSUE_NUMBER, \r\nISSUE_DATETIME, \r\nISSUE_LOCAL_DATETIME, \r\nCONTINUATION, \r\nSTART_DISTANCE, \r\nEND_DISTANCE, \r\nUNITS, \r\nVEHICLE_WEIGHT, \r\nTYPE_NAME as LICENCE_TYPE, \r\nSTATUS, \r\nSTATUS_LAST_MODIFIED_DATETIME, \r\nSTATUS_LAST_MODIFIED_LOCAL_DATETIME, \r\nDOLLAR_VALUE, \r\nCREDIT, \r\nAMOUNT, \r\nREGISTRATION_PLATE, \r\nFEE_AMOUNT, \r\nFEE_AMOUNT_GST, \r\nRUC_VEHICLE_TYPE, \r\nVEHICLE_COMBINATION, \r\nRUC_WEIGHT_FLAG, \r\nLOAD_DATETIME \r\nFROM \"DEV\".core_extensions.vehicle_licence l \r\nINNER JOIN \"DEV\".\"EDC_INTERNAL\".\"ACCOUNT_ORGANISATION_ACCESS\" aoa \r\n  ON l.ORGANISATION_ID = aoa.ORGANISATION_ID\r\n AND LOWER(aoa.REGION) = LOWER('apac')\r\n AND UPPER(aoa.CLOUD)  = UPPER('AWS')\r\nWHERE l.ORGANISATION_ID IS NOT NULL QUALIFY ROW_NUMBER() OVER (PARTITION BY l.CENTRAL_ID, l.ORGANISATION_ID, l.MACHINE_ID ORDER BY l.LOAD_DATETIME DESC) = 1;\r\n",
            "refresh_mode": "AUTO",
            "refresh_mode_reason": "",
            "rows": 0,
            "scheduling_state": "ACTIVE",
            "schema": "AWS_APAC",
            "target_lag": [
              {
                "downstream": false,
                "maximum_duration": "30 minutes"
              }
            ],
            "timeouts": null,
            "warehouse": "WH_EDC_DEV"
          },
